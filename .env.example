# Chain Analytics — API Keys
# ─────────────────────────────────────────────────────────────

# Etherscan V2 (REQUIRED) — covers ETH, ARB, MATIC, and more
# Get free key: https://etherscan.io/myapikey
ETHERSCAN_KEY=your_etherscan_key_here

# Alchemy (OPTIONAL) — enables chain-wide transfer queries
# Get free key: https://alchemy.com → Create App → Copy API Key
ALCHEMY_KEY=your_alchemy_key_here

# The Graph (OPTIONAL) — enables proper Uniswap/Aave DeFi data
# Get free key: https://thegraph.com/studio → API Keys → Create
GRAPH_KEY=your_graph_key_here
